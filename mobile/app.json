{
  "expo": {
    "name": "HaderaPay",
    "slug": "haderapay-mobile",
    "version": "0.1.23",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "haderapay",
    "icon": "./assets/haderapay-icon.png",
    "android": {
      "package": "com.haderapay.mobile",
      "versionCode": 24,
      "adaptiveIcon": {
        "foregroundImage": "./assets/haderapay-icon.png",
        "backgroundColor": "#ffffff"
      }
    },
    "splash": {
      "backgroundColor": "#eef2f4",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      "expo-audio",
      "expo-notifications"
    ]
  }
}
